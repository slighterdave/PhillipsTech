# PhillipsTech Backend – Environment Variables
#
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env
#   nano .env          # fill in the real values
#
# NEVER commit .env to version control.

# ── Required ────────────────────────────────────────────────────────────────

# Secret key used to sign JWTs.
# Generate a strong random value with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── Optional ────────────────────────────────────────────────────────────────

# Port the backend listens on (default: 3000)
PORT=3000

# How long login tokens are valid for (default: 24h)
# Accepts any value accepted by the jsonwebtoken library, e.g. 1h, 7d
TOKEN_TTL=24h

# Allowed CORS origin for API requests.
# In production set this to the site's public URL, e.g. https://phillipstech.info
ALLOWED_ORIGIN=https://phillipstech.info

# Path to the SQLite database file (default: ./phillipstech.db)
# DB_PATH=/var/www/phillipstech/backend/phillipstech.db

# ── Gmail Integration (optional) ────────────────────────────────────────────
# Gmail credentials are stored in the database via Admin → Settings.
# No environment variables are needed for Gmail; configure the Gmail address
# and App Password through the Settings page in the admin portal.
# See: https://myaccount.google.com/apppasswords (requires 2-Step Verification)
